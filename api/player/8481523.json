offs", "value": "-0.20 WAR", "tone": "neg"}, {"label": "Total, last 3 seasons", "value": "+0.10 WAR", "tone": "pos", "strong": true}], "summary": "His total on-ice value, converted to WINS (WAR). It adds up everything he does \u2014 even-strength play, the power play and penalty kill, his penalty discipline RELATIVE TO HIS POSITION (defensemen structurally take more than they draw, so only the differential vs other D counts), and faceoffs \u2014 and the grade ranks that total against other players at his position over the last three seasons.", "method": "Total WAR sums these four, each priced in wins. The grade is this player's percentile vs same-position peers over the 3-season window."}, "overall": {"receipts": [{"label": "5v5 xG impact (RAPM)", "value": "-0.13 xG/60", "tone": "neg", "strong": true}, {"label": "\u2014 offense", "value": "+0.04 xG/60", "tone": "neutral"}, {"label": "\u2014 defense", "value": "-0.17 xG/60", "tone": "neg"}, {"label": "5v5 sample", "value": "1,129 min", "tone": "neutral"}, {"label": "On-ice xG share", "value": "45.9%", "tone": "neutral"}, {"label": "Relative to team (on \u2212 off ice)", "value": "-1.6%", "tone": "neg"}], "summary": "His two-way impact at 5-on-5: do his team's scoring chances go UP, and the other team's go DOWN, when he's on the ice? We isolate his effect from his linemates, the competition, and where his shifts start \u2014 so it's his fingerprint on the play, not just his teammates' work.", "method": "Teammate-, competition- and zone-start-adjusted 5v5 expected goals, via ridge regression over shift stints. An impact estimate, not a box score."}, "offense": {"receipts": [{"label": "Offensive xG impact (RAPM)", "value": "+0.04 xG/60", "tone": "neutral", "strong": true}, {"label": "On-ice xG created", "value": "24", "tone": "neutral"}, {"label": "Relative on-ice xG%", "value": "-1.6%", "tone": "neg"}], "summary": "His effect on the chances his team CREATES at 5-on-5 \u2014 how much shot-quality (expected goals) his line generates with him out there, after adjusting for who he plays with and against.", "method": "His share of 5v5 expected-goals creation, adjusted for who he plays with and against."}, "defense": {"receipts": [{"label": "Defensive xG impact (RAPM)", "value": "-0.17 xG/60", "tone": "neg", "strong": true}, {"label": "On-ice xG allowed", "value": "28", "tone": "neutral"}], "summary": "His effect on the chances his team ALLOWS at 5-on-5 \u2014 how well shot-quality against is held down with him on the ice, after adjusting for teammates and competition. A higher grade means fewer good chances against.", "method": "His suppression of 5v5 expected goals against, teammate- and competition-adjusted. Higher means fewer chances allowed while he's on the ice."}, "ppOffense": {"receipts": [{"label": "Power-play xG impact (RAPM)", "value": "-0.14 xG/60", "tone": "neg", "strong": true}, {"label": "PP ice time", "value": "128 min", "tone": "neutral"}], "summary": "His impact on the POWER PLAY \u2014 how much his team's chances improve with him on the man advantage, graded only against players who actually log power-play minutes (so a bottom-six grinder isn't penalized for never being out there).", "method": "Power-play expected-goals impact, RAPM-adjusted. Graded vs peers who actually play the PP."}, "pkDefense": {"receipts": [{"label": "Penalty-kill xG suppression (RAPM)", "value": "+0.00 xG/60", "tone": "neutral", "strong": true}, {"label": "PK ice time", "value": "2 min", "tone": "neutral"}], "summary": "His impact on the PENALTY KILL \u2014 how well his team smothers chances while short-handed with him on the ice, graded against other penalty-killers.", "method": "Penalty-kill expected-goals suppression, RAPM-adjusted."}, "finishing": {"receipts": [{"label": "Career shots", "value": "695", "tone": "neutral"}, {"label": "Goals", "value": "55", "tone": "neutral"}, {"label": "Goals above expected", "value": "-8.2", "tone": "neg"}, {"label": "True talent / 100 shots", "value": "-0.67", "tone": "neg", "strong": true}, {"label": "Reliability", "value": "57%", "tone": "neutral"}], "summary": "Whether he scores MORE goals than the quality of his shots would predict \u2014 pure finishing talent. We take his goals minus the expected goals on every shot of his career, then trust it more the more he's shot (a 2,000-shot sample is real; a 200-shot hot streak isn't yet).", "method": "Goals minus expected over career shots, then regressed to the mean by sample size. A high-volume shooter earns a more confident read (higher reliability)."}}, "skills": {"hits60": {"receipts": [{"label": "Physicality rate", "value": "5.00 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Physicality", "summary": "Physicality is how often he throws a body check \u2014 counted straight from the NHL's play-by-play. He's logged 206 hits over his last 152 games (5.0 per 60 minutes on the ice), and the grade ranks that against other forwards.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "blocks60": {"receipts": [{"label": "Shot blocking rate", "value": "2.52 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Shot blocking", "summary": "Shot blocking is how willing he is to get in a shooting lane \u2014 counted straight from the NHL's play-by-play. He's logged 104 blocked shots over his last 152 games (2.5 per 60 minutes on the ice), and the grade ranks that against other forwards.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "takeaways60": {"receipts": [{"label": "Puck stripping rate", "value": "1.17 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Puck stripping", "summary": "Puck stripping is how often he strips the puck off an opponent \u2014 counted straight from the NHL's play-by-play. He's logged 48 takeaways over his last 152 games (1.2 per 60 minutes on the ice), and the grade ranks that against other forwards.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "giveaways60": {"receipts": [{"label": "Puck security rate", "value": "2.11 / 60", "tone": "neutral"}, {"label": "Direction", "value": "fewer is better", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Puck security", "summary": "Puck security is how often he turns the puck over (fewer is better) \u2014 counted straight from the NHL's play-by-play. He's logged 87 giveaways over his last 152 games (2.1 per 60 minutes on the ice), and the grade ranks that against other forwards.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "primary_assists60": {"receipts": [{"label": "Playmaking rate", "value": "0.51 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Playmaking", "summary": "Playmaking is how often he makes the primary pass on a goal \u2014 0.51 per 60 minutes of ice time over his last 3 seasons, ranked against other forwards."}, "rush_xg60": {"receipts": [{"label": "Rush offense rate", "value": "0.09 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Rush offense", "summary": "Rush offense is the danger of the chances he creates off the rush \u2014 0.09 per 60 minutes of ice time over his last 3 seasons, ranked against other forwards."}}}, "projection": {"available": true, "asOfSeason": 20252026, "baseWar": 0.2, "years": [{"horizon": 1, "seasonId": 20262027,