: {"value": {"receipts": [{"label": "Even strength (5v5)", "value": "+0.71 WAR", "tone": "pos"}, {"label": "Special teams (PP + PK)", "value": "-0.20 WAR", "tone": "neg"}, {"label": "Penalty discipline (vs position)", "value": "+0.36 WAR", "tone": "pos"}, {"label": "Faceoffs", "value": "-0.06 WAR", "tone": "neg"}, {"label": "Total, last 3 seasons", "value": "+0.62 WAR", "tone": "pos", "strong": true}], "summary": "His total on-ice value, converted to WINS (WAR). It adds up everything he does \u2014 even-strength play, the power play and penalty kill, his penalty discipline RELATIVE TO HIS POSITION (defensemen structurally take more than they draw, so only the differential vs other D counts), and faceoffs \u2014 and the grade ranks that total against other players at his position over the last three seasons.", "method": "Total WAR sums these four, each priced in wins. The grade is this player's percentile vs same-position peers over the 3-season window."}, "overall": {"receipts": [{"label": "5v5 xG impact (RAPM)", "value": "+0.01 xG/60", "tone": "neutral", "strong": true}, {"label": "\u2014 offense", "value": "+0.07 xG/60", "tone": "pos"}, {"label": "\u2014 defense", "value": "-0.07 xG/60", "tone": "neg"}, {"label": "5v5 sample", "value": "2,518 min", "tone": "neutral"}, {"label": "On-ice xG share", "value": "47.6%", "tone": "neutral"}, {"label": "Relative to team (on \u2212 off ice)", "value": "-5.0%", "tone": "neg"}], "summary": "His two-way impact at 5-on-5: do his team's scoring chances go UP, and the other team's go DOWN, when he's on the ice? We isolate his effect from his linemates, the competition, and where his shifts start \u2014 so it's his fingerprint on the play, not just his teammates' work.", "method": "Teammate-, competition- and zone-start-adjusted 5v5 expected goals, via ridge regression over shift stints. An impact estimate, not a box score."}, "offense": {"receipts": [{"label": "Offensive xG impact (RAPM)", "value": "+0.07 xG/60", "tone": "pos", "strong": true}, {"label": "On-ice xG created", "value": "46", "tone": "neutral"}, {"label": "Relative on-ice xG%", "value": "-5.0%", "tone": "neg"}], "summary": "His effect on the chances his team CREATES at 5-on-5 \u2014 how much shot-quality (expected goals) his line generates with him out there, after adjusting for who he plays with and against.", "method": "His share of 5v5 expected-goals creation, adjusted for who he plays with and against."}, "defense": {"receipts": [{"label": "Defensive xG impact (RAPM)", "value": "-0.07 xG/60", "tone": "neg", "strong": true}, {"label": "On-ice xG allowed", "value": "51", "tone": "neutral"}], "summary": "His effect on the chances his team ALLOWS at 5-on-5 \u2014 how well shot-quality against is held down with him on the ice, after adjusting for teammates and competition. A higher grade means fewer good chances against.", "method": "His suppression of 5v5 expected goals against, teammate- and competition-adjusted. Higher means fewer chances allowed while he's on the ice."}, "ppOffense": {"receipts": [{"label": "Power-play xG impact (RAPM)", "value": "+0.00 xG/60", "tone": "neutral", "strong": true}, {"label": "PP ice time", "value": "23 min", "tone": "neutral"}], "summary": "His impact on the POWER PLAY \u2014 how much his team's chances improve with him on the man advantage, graded only against players who actually log power-play minutes (so a bottom-six grinder isn't penalized for never being out there).", "method": "Power-play expected-goals impact, RAPM-adjusted. Graded vs peers who actually play the PP."}, "pkDefense": {"receipts": [{"label": "Penalty-kill xG suppression (RAPM)", "value": "-0.28 xG/60", "tone": "neg", "strong": true}, {"label": "PK ice time", "value": "174 min", "tone": "neutral"}], "summary": "His impact on the PENALTY KILL \u2014 how well his team smothers chances while short-handed with him on the ice, graded against other penalty-killers.", "method": "Penalty-kill expected-goals suppression, RAPM-adjusted."}, "finishing": {"receipts": [{"label": "Career shots", "value": "651", "tone": "neutral"}, {"label": "Goals", "value": "55", "tone": "neutral"}, {"label": "Goals above cell-expected", "value": "+1.1", "tone": "pos"}, {"label": "Finishing / 100 shots", "value": "-0.29", "tone": "neg", "strong": true}, {"label": "95% band", "value": "-1.76 \u2026 +1.19", "tone": "neutral"}, {"label": "Sample", "value": "fair", "tone": "neutral"}], "summary": "Whether he converts MORE than an average shooter at his position would on the same shots \u2014 with each shot priced by how league shooters actually convert its CONTEXT (danger band \u00d7 strength state \u00d7 rebound), not just its geometry. Trusted more the more he's shot; the band says how sure we are.", "method": "Goals minus cell-expected goals per 100 shots, centered within position, then shrunk toward a shot-speed-informed prior by sample size (younger samples shrink harder). Cells are fit walk-forward \u2014 a season is priced only by the seasons before it. This is the same finishing number the WAR stack uses."}}, "skills": {"hits60": {"receipts": [{"label": "Physicality rate", "value": "2.45 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Physicality", "summary": "Physicality is how often he throws a body check \u2014 counted straight from the NHL's play-by-play. He's logged 132 hits over his last 220 games (2.5 per 60 minutes on the ice), and the grade ranks that against other forwards.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "blocks60": {"receipts": [{"label": "Shot blocking rate", "value": "4.94 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Shot blocking", "summary": "Shot blocking is how willing he is to get in a shooting lane \u2014 counted straight from the NHL's play-by-play. He's logged 266 blocked shots over his last 220 games (4.9 per 60 minutes on the ice), and the grade ranks that against other forwards.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "takeaways60": {"receipts": [{"label": "Puck stripping rate", "value": "0.95 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Puck stripping", "summary": "Puck stripping is how often he strips the puck off an opponent \u2014 counted straight from the NHL's play-by-play. He's logged 51 takeaways over his last 220 games (0.9 per 60 minutes on the ice), and the grade ranks that against other forwards.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "giveaways60": {"receipts": [{"label": "Puck security rate", "value": "1.90 / 60", "tone": "neutral"}, {"label": "Direction", "value": "fewer is better", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Puck security", "summary": "Puck security is how often he turns the puck over (fewer is better) \u2014 counted straight from the NHL's play-by-play. He's logged 102 giveaways over his last 220 games (1.9 per 60 minutes on the ice), and the grade ranks that against other forwards.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "primary_assists60": {"receipts": [{"label": "Playmaking rate", "value": "0.80 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Playmaking", "summary": "Playmaking is how often he makes the primary pass on a goal \u2014 0.80 per 60 minutes of ice time over his last 3 seasons, ranked against other 