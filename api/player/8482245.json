ng": {"receipts": [{"label": "Career shots", "value": "610", "tone": "neutral"}, {"label": "Goals", "value": "24", "tone": "neutral"}, {"label": "Goals above cell-expected", "value": "+2.0", "tone": "pos"}, {"label": "Finishing / 100 shots", "value": "+0.36", "tone": "pos", "strong": true}, {"label": "95% band", "value": "-1.14 \u2026 +1.86", "tone": "neutral"}, {"label": "Sample", "value": "fair", "tone": "neutral"}], "summary": "Whether he converts MORE than an average shooter at his position would on the same shots \u2014 with each shot priced by how league shooters actually convert its CONTEXT (danger band \u00d7 strength state \u00d7 rebound), not just its geometry. Trusted more the more he's shot; the band says how sure we are.", "method": "Goals minus cell-expected goals per 100 shots, centered within position, then shrunk toward a shot-speed-informed prior by sample size (younger samples shrink harder). Cells are fit walk-forward \u2014 a season is priced only by the seasons before it. This is the same finishing number the WAR stack uses."}}, "skills": {"hits60": {"receipts": [{"label": "Physicality rate", "value": "3.68 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Physicality", "summary": "Physicality is how often he throws a body check \u2014 counted straight from the NHL's play-by-play. He's logged 263 hits over his last 206 games (3.7 per 60 minutes on the ice), and the grade ranks that against other defensemen.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "blocks60": {"receipts": [{"label": "Shot blocking rate", "value": "5.03 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Shot blocking", "summary": "Shot blocking is how willing he is to get in a shooting lane \u2014 counted straight from the NHL's play-by-play. He's logged 360 blocked shots over his last 206 games (5.0 per 60 minutes on the ice), and the grade ranks that against other defensemen.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "takeaways60": {"receipts": [{"label": "Puck stripping rate", "value": "0.83 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Puck stripping", "summary": "Puck stripping is how often he strips the puck off an opponent \u2014 counted straight from the NHL's play-by-play. He's logged 59 takeaways over his last 206 games (0.8 per 60 minutes on the ice), and the grade ranks that against other defensemen.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "giveaways60": {"receipts": [{"label": "Puck security rate", "value": "2.22 / 60", "tone": "neutral"}, {"label": "Direction", "value": "fewer is better", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Puck security", "summary": "Puck security is how often he turns the puck over (fewer is better) \u2014 counted straight from the NHL's play-by-play. He's logged 159 giveaways over his last 206 games (2.2 per 60 minutes on the ice), and the grade ranks that against other defensemen.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "primary_assists60": {"receipts": [{"label": "Playmaking rate", "value": "0.39 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Playmaking", "summary": "Playmaking is how often he makes the primary pass on a goal \u2014 0.39 per 60 minutes of ice time over his last 3 seasons, ranked against other defensemen."}, "rush_xg60": {"receipts": [{"label": "Rush offense rate", "value": "0.04 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Rush offense", "summary": "Rush offense is the danger of the chances he creates off the rush \u2014 0.04 per 60 minutes of ice time over his last 3 seasons, ranked against other defensemen."}}}, "projection": {"available": true, "asOfSeason": 20252026, "baseWar": 0.69, "years": [{"horizon": 1, "seasonId": 20262027, "age": 31.0, "projWar": 0.65, "lo": 0.06, "hi": 1.24}, {"horizon": 2, "seasonId": 20272028, "age": 32.0, "projWar": 0.59, "lo": -0.02, "hi": 1.2}, {"horizon": 3, "seasonId": 20282029, "age": 33.0, "projWar": 0.54, "lo": -0.1, "hi": 1.18}, {"horizon": 4, "seasonId": 20292030, "age": 34.0, "projWar": 0.48, "lo": -0.18, "hi": 1.14}, {"horizon": 5, "seasonId": 20302031, "age": 35.0, "projWar": 0.41, "lo": -0.27, "hi": 1.09}]}, "clause": {"hasNmc": false, "hasNtc": true, "noTradeListSize": 10, "label": "Modified NTC (10-team)", "terms": "M-NTC", "details": "M-NTC: 10 team no-trade list"}, "trajectory": {"available": true, "direction": "down", "tier": "regression", "label": "Regression risk", "detail": "Priced on strong past seasons, but his current-season impact is well below that -- the value below may be propping him up.", "gap": -0.7, "currentWar": 0.09, "windowWar": 0.79, "currentSeason": 20252026}, "debutComps": null, "scorecard": {"offense": 5, "defense": 98, "overall": 52, "peers": 776, "window": "multi-year RAPM (recent 3 seasons)", "recent": {"offense": 8, "defense": 74, "overall": 31, "season": 20252026, "peers": 673}, "value": 79, "valueGroup": "D", "valueTrend": [{"season": 20222023, "pctl": 59}, {"season": 20232024, "pctl": 84}, {"season": 20242025, "pctl": 86}, {"season": 20252026, "pctl": 41}], "finishing": 74, "pkDefense": 90}, "skills": {"percentiles": {"hits60": 56.5, "blocks60": 66.3, "takeaways60": 44.5, "giveaways60": 74.9, "primary_assist