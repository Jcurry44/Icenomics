card": {"value": {"receipts": [{"label": "Even strength (5v5)", "value": "+2.25 WAR", "tone": "pos"}, {"label": "Special teams (PP + PK)", "value": "+0.84 WAR", "tone": "pos"}, {"label": "Penalty discipline (vs position)", "value": "+0.27 WAR", "tone": "pos"}, {"label": "Faceoffs", "value": "+0.45 WAR", "tone": "pos"}, {"label": "Total, last 3 seasons", "value": "+4.69 WAR", "tone": "pos", "strong": true}], "summary": "His total on-ice value, converted to WINS (WAR). It adds up everything he does \u2014 even-strength play, the power play and penalty kill, his penalty discipline RELATIVE TO HIS POSITION (defensemen structurally take more than they draw, so only the differential vs other D counts), and faceoffs \u2014 and the grade ranks that total against other players at his position over the last three seasons.", "method": "Total WAR sums these four, each priced in wins. The grade is this player's percentile vs same-position peers over the 3-season window."}, "overall": {"receipts": [{"label": "5v5 xG impact (RAPM)", "value": "+0.15 xG/60", "tone": "pos", "strong": true}, {"label": "\u2014 offense", "value": "+0.16 xG/60", "tone": "pos"}, {"label": "\u2014 defense", "value": "-0.01 xG/60", "tone": "neutral"}, {"label": "5v5 sample", "value": "2,497 min", "tone": "neutral"}, {"label": "On-ice xG share", "value": "54.5%", "tone": "neutral"}, {"label": "Relative to team (on \u2212 off ice)", "value": "+5.4%", "tone": "pos"}], "summary": "His two-way impact at 5-on-5: do his team's scoring chances go UP, and the other team's go DOWN, when he's on the ice? We isolate his effect from his linemates, the competition, and where his shifts start \u2014 so it's his fingerprint on the play, not just his teammates' work.", "method": "Teammate-, competition- and zone-start-adjusted 5v5 expected goals, via ridge regression over shift stints. An impact estimate, not a box score."}, "offense": {"receipts": [{"label": "Offensive xG impact (RAPM)", "value": "+0.16 xG/60", "tone": "pos", "strong": true}, {"label": "On-ice xG created", "value": "29", "tone": "neutral"}, {"label": "Relative on-ice xG%", "value": "+5.4%", "tone": "pos"}], "summary": "His effect on the chances his team CREATES at 5-on-5 \u2014 how much shot-quality (expected goals) his line generates with him out there, after adjusting for who he plays with and against.", "method": "His share of 5v5 expected-goals creation, adjusted for who he plays with and against."}, "defense": {"receipts": [{"label": "Defensive xG impact (RAPM)", "value": "-0.01 xG/60", "tone": "neutral", "strong": true}, {"label": "On-ice xG allowed", "value": "24", "tone": "neutral"}], "summary": "His effect on the chances his team ALLOWS at 5-on-5 \u2014 how well shot-quality against is held down with him on the ice, after adjusting for teammates and competition. A higher grade means fewer good chances against.", "method": "His suppression of 5v5 expected goals against, teammate- and competition-adjusted. Higher means fewer chances allowed while he's on the ice."}, "ppOffense": {"receipts": [{"label": "Power-play xG impact (RAPM)", "value": "+0.52 xG/60", "tone": "pos", "strong": true}, {"label": "PP ice time", "value": "154 min", "tone": "neutral"}], "summary": "His impact on the POWER PLAY \u2014 how much his team's chances improve with him on the man advantage, graded only against players who actually log power-play minutes (so a bottom-six grinder isn't penalized for never being out there).", "method": "Power-play expected-goals impact, RAPM-adjusted. Graded vs peers who actually play the PP."}, "pkDefense": {"receipts": [{"label": "Penalty-kill xG suppression (RAPM)", "value": "+0.00 xG/60", "tone": "neutral", "strong": true}, {"label": "PK ice time", "value": "28 min", "tone": "neutral"}], "summary": "His impact on the PENALTY KILL \u2014 how well his team smothers chances while short-handed with him on the ice, graded against other penalty-killers.", "method": "Penalty-kill expected-goals suppression, RAPM-adjusted."}, "finishing": {"receipts": [{"label": "Career shots", "value": "1,661", "tone": "neutral"}, {"label": "Goals", "value": "192", "tone": "neutral"}, {"label": "Goals above expected", "value": "+22.0", "tone": "pos"}, {"label": "True talent / 100 shots", "value": "+1.01", "tone": "pos", "strong": true}, {"label": "Reliability", "value": "76%", "tone": "neutral"}], "summary": "Whether he scores MORE goals than the quality of his shots would predict \u2014 pure finishing talent. We take his goals minus the expected goals on every shot of his career, then trust it more the more he's shot (a 2,000-shot sample is real; a 200-shot hot streak isn't yet).", "method": "Goals minus expected over career shots, then regressed to the mean by sample size. A high-volume shooter earns a more confident read (higher reliability)."}}, "skills": {"hits60": {"receipts": [{"label": "Physicality rate", "value": "2.50 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Physicality", "summary": "Physicality is how often he throws a body check \u2014 counted straight from the NHL's play-by-play. He's logged 149 hits over his last 209 games (2.5 per 60 minutes on the ice), and the grade ranks that against other forwards.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "blocks60": {"receipts": [{"label": "Shot blocking rate", "value": "1.71 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Shot blocking", "summary": "Shot blocking is how willing he is to get in a shooting lane \u2014 counted straight from the NHL's play-by-play. He's logged 102 blocked shots over his last 209 games (1.7 per 60 minutes on the ice), and the grade ranks that against other forwards.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far mor