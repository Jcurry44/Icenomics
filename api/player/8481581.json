le", "value": "4,016 min", "tone": "neutral"}, {"label": "On-ice xG share", "value": "49.7%", "tone": "neutral"}, {"label": "Relative to team (on \u2212 off ice)", "value": "-1.7%", "tone": "neg"}], "summary": "His two-way impact at 5-on-5: do his team's scoring chances go UP, and the other team's go DOWN, when he's on the ice? We isolate his effect from his linemates, the competition, and where his shifts start \u2014 so it's his fingerprint on the play, not just his teammates' work.", "method": "Teammate-, competition- and zone-start-adjusted 5v5 expected goals, via ridge regression over shift stints. An impact estimate, not a box score."}, "offense": {"receipts": [{"label": "Offensive xG impact (RAPM)", "value": "+0.17 xG/60", "tone": "pos", "strong": true}, {"label": "On-ice xG created", "value": "62", "tone": "neutral"}, {"label": "Relative on-ice xG%", "value": "-1.7%", "tone": "neg"}], "summary": "His effect on the chances his team CREATES at 5-on-5 \u2014 how much shot-quality (expected goals) his line generates with him out there, after adjusting for who he plays with and against.", "method": "His share of 5v5 expected-goals creation, adjusted for who he plays with and against."}, "defense": {"receipts": [{"label": "Defensive xG impact (RAPM)", "value": "-0.04 xG/60", "tone": "neutral", "strong": true}, {"label": "On-ice xG allowed", "value": "62", "tone": "neutral"}], "summary": "His effect on the chances his team ALLOWS at 5-on-5 \u2014 how well shot-quality against is held down with him on the ice, after adjusting for teammates and competition. A higher grade means fewer good chances against.", "method": "His suppression of 5v5 expected goals against, teammate- and competition-adjusted. Higher means fewer chances allowed while he's on the ice."}, "ppOffense": {"receipts": [{"label": "Power-play xG impact (RAPM)", "value": "-0.04 xG/60", "tone": "neutral", "strong": true}, {"label": "PP ice time", "value": "110 min", "tone": "neutral"}], "summary": "His impact on the POWER PLAY \u2014 how much his team's chances improve with him on the man advantage, graded only against players who actually log power-play minutes (so a bottom-six grinder isn't penalized for never being out there).", "method": "Power-play expected-goals impact, RAPM-adjusted. Graded vs peers who actually play the PP."}, "pkDefense": {"receipts": [{"label": "Penalty-kill xG suppression (RAPM)", "value": "+0.08 xG/60", "tone": "pos", "strong": true}, {"label": "PK ice time", "value": "92 min", "tone": "neutral"}], "summary": "His impact on the PENALTY KILL \u2014 how well his team smothers chances while short-handed with him on the ice, graded against other penalty-killers.", "method": "Penalty-kill expected-goals suppression, RAPM-adjusted."}, "finishing": {"receipts": [{"label": "Career shots", "value": "701", "tone": "neutral"}, {"label": "Goals", "value": "38", "tone": "neutral"}, {"label": "Goals above expected", "value": "+5.5", "tone": "pos"}, {"label": "True talent / 100 shots", "value": "+0.45", "tone": "pos", "strong": true}, {"label": "Reliability", "value": "57%", "tone": "neutral"}], "summary": "Whether he scores MORE goals than the quality of his shots would predict \u2014 pure finishing talent. We take his goals minus the expected goals on every shot of his career, then trust it more the more he's shot (a 2,000-shot sample is real; a 200-shot hot streak isn't yet).", "method": "Goals minus expected over career shots, then regressed to the mean by sample size. A high-volume shooter earns a more confident read (higher reliability)."}}, "skills": {"hits60": {"receipts": [{"label": "Physicality rate", "value": "1.64 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Physicality", "summary": "Physicality is how often he throws a body check \u2014 counted straight from the NHL's play-by-play. He's logged 139 hits over his last 227 games (1.6 per 60 minutes on the ice), a