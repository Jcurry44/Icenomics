6, -0.18, -0.21, -0.25, -0.29], "fairAav": 775000, "totalValue": 4650000}, {"years": 7, "endAge": 31, "projectedWar": [-0.16, -0.16, -0.18, -0.21, -0.25, -0.29, -0.34], "fairAav": 775000, "totalValue": 5425000}, {"years": 8, "endAge": 32, "projectedWar": [-0.16, -0.16, -0.18, -0.21, -0.25, -0.29, -0.34, -0.39], "fairAav": 775000, "totalValue": 6200000}], "note": "Fair AAV = average projected annual market value over the term (aging-curve WAR walk x $4.71M/WAR, each year floored at the league minimum). Longer terms average in decline years, so the fair AAV falls. Real deals carry a term/security premium this does not model -- it is the production-fair anchor, not a prediction of the signing."}, "contractProjection": {"seasonStart": 2026, "status": "RFA", "aavLow": 1141911, "aavMid": 1486582, "aavHigh": 2866303, "capPctMid": 1.4, "term": 2, "comps": [{"name": "Jeremy Lauzon", "age": 25, "aav": 2000000, "term": 4, "year": 2022, "status": "RFA"}, {"name": "Dylan McIlrath", "age": 24, "aav": 800000, "term": 1, "year": 2016, "status": "RFA"}, {"name": "Nikita Zadorov", "age": 25, "aav": 3200000, "term": 1, "year": 2020, "status": "RFA"}, {"name": "Nikita Zadorov", "age": 26, "aav": 3750000, "term": 1, "year": 2021, "status": "RFA"}, {"name": "Jamie Oleksiak", "age": 24, "aav": 918750, "term": 1, "year": 2016, "status": "RFA"}, {"name": "Nikita Zadorov", "age": 24, "aav": 3200000, "term": 1, "year": 2019, "status": "RFA"}], "bridge": {"aavLow": 1037117, "aavMid": 1486582, "aavHigh": 1705670, "term": 2, "capPctMid": 1.4, "n": 14}, "longTerm": {"aavLow": 1060899, "aavMid": 1162500, "aavHigh": 1382093, "term": 6, "capPctMid": 5.4, "n": 14, "rawAavMid": 5655555, "bounded": true, "boundNote": "Capped to ~1.5x his on-ice impact \u2014 few players at his impact sign 5+yr deals, so the raw long-term comps skew high."}}, "contractAudit": {"predSeason": 2026, "asOf": "2026-06-26", "status": "RFA", "projLow": 1141911, "projMid": 1486582, "projHigh": 2866303, "projTerm": 2, "state": "pending", "bridge": {"aavLow": 1188296, "aavMid": 1500146, "aavHigh": 1966890, "term": 2, "capPctMid": 1.4, "n": 14}, "longTerm": {"aavLow": 5161269, "aavMid": 5655555, "aavHigh": 6723874, "term": 6, "capPctMid": 5.4, "n": 14}, "matched": null, "actualAav": null, "actualTerm": null, "inBand": null, "err": null, "actualDate": null}, "explain": {"scorecard": {"value": {"receipts": [{"label": "Even strength (5v5)", "value": "+0.38 WAR", "tone": "pos"}, {"label": "Special teams (PP + PK)", "value": "-0.13 WAR", "tone": "neg"}, {"label": "Penalty discipline (vs position)", "value": "-0.89 WAR", "tone": "neg"}, {"label": "Faceoffs", "value": "+0.00 WAR", "tone": "neutral"}, {"label": "Total, last 3 seasons", "value": "-0.52 WAR", "tone": "neg", "strong": true}], "summary": "His total on-ice value, converted to WINS (WAR). It adds up everything he does \u2014 even-strength play, the power play and penalty kill, his penalty discipline RELATIVE TO HIS POSITION (defensemen structurally take more than they draw, so only the differential vs other D counts), and faceoffs \u2014 and the grade ranks that total against other players at his position over the last three seasons.", "method": "Total WAR sums these four, each priced in wins. The grade is this player's percentile vs same-position peers over the 3-season window."}, "overall": {"receipts": [{"label": "5v5 xG impact (RAPM)", "value": "-0.08 xG/60", "tone": "neg", "strong": true}, {"label": "\u2014 offense", "value": "-0.08 xG/60", "tone": "neg"}, {"label": "\u2014 defense", "value": "-0.01 xG/60", "tone": "neutral"}, {"label": "5v5 sample", "value": "2,204 min", "tone": "neutral"}, {"label": "On-ice xG share", "value": "47.1%", "tone": "neutral"}, {"label": "Relative to team (on \u2212 off ice)", "value": "-0.8%", "tone": "neg"}], "summary": "His two-way impact at 5-on-5: do his team's scoring chances go UP, and the other team's go DOWN, when he's on the ice? We isolate his effect from his linemates, the competition, and wh