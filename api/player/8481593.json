el": "Total, last 3 seasons", "value": "+0.46 WAR", "tone": "pos", "strong": true}], "summary": "His total on-ice value, converted to WINS (WAR). It adds up everything he does \u2014 even-strength play, the power play and penalty kill, his penalty discipline RELATIVE TO HIS POSITION (defensemen structurally take more than they draw, so only the differential vs other D counts), and faceoffs \u2014 and the grade ranks that total against other players at his position over the last three seasons.", "method": "Total WAR sums these four, each priced in wins. The grade is this player's percentile vs same-position peers over the 3-season window."}, "overall": {"receipts": [{"label": "5v5 xG impact (RAPM)", "value": "-0.08 xG/60", "tone": "neg", "strong": true}, {"label": "\u2014 offense", "value": "-0.13 xG/60", "tone": "neg"}, {"label": "\u2014 defense", "value": "+0.05 xG/60", "tone": "neutral"}, {"label": "5v5 sample", "value": "2,356 min", "tone": "neutral"}, {"label": "On-ice xG share", "value": "46.7%", "tone": "neutral"}, {"label": "Relative to team (on \u2212 off ice)", "value": "-0.5%", "tone": "neg"}], "summary": "His two-way impact at 5-on-5: do his team's scoring chances go UP, and the other team's go DOWN, when he's on the ice? We isolate his effect from his linemates, the competition, and where his shifts start \u2014 so it's his fingerprint on the play, not just his teammates' work.", "method": "Teammate-, competition- and zone-start-adjusted 5v5 expected goals, via ridge regression over shift stints. An impact estimate, not a box score."}, "offense": {"receipts": [{"label": "Offensive xG impact (RAPM)", "value": "-0.13 xG/60", "tone": "neg", "strong": true}, {"label": "On-ice xG created", "value": "37", "tone": "neutral"}, {"label": "Relative on-ice xG%", "value": "-0.5%", "tone": "neg"}], "summary": "His effect on the chances his team CREATES at 5-on-5 \u2014 how much shot-quality (expected goals) his line generates with him out there, after adjusting for who he plays with and against.", "method": "His share of 5v5 expected-goals creation, adjusted for who he plays with and against."}, "defense": {"receipts": [{"label": "Defensive xG impact (RAPM)", "value": "+0.05 xG/60", "tone": "neutral", "strong": true}, {"label": "On-ice xG allowed", "value": "42", "tone": "neutral"}], "summary": "His effect on the chances his team ALLOWS at 5-on-5 \u2014 how well shot-quality against is held down with him on the ice, after adjusting for teammates and competition. A higher grade means fewer good chances against.", "method": "His suppression of 5v5 expected goals against, teammate- and competition-adjusted. Higher means fewer chances allowed while he's on the ice."}, "finishing": {"receipts": [{"label": "Career shots", "value": "186", "tone": "neutral"}, {"label": "Goals", "value": "7", "tone": "neutral"}, {"label": "Goals above cell-expected", "value": "+1.6", "tone": "pos"}, {"label": "Finishing / 100 shots", "value": "+0.11", "tone": "pos", "strong": true}, {"label": "95% band", "value": "-1.74 \u2026 +1.96", "tone": "neutral"}, {"label": "Sample", "value": "thin", "tone": "neutral"}], "summary": "Whether he converts MORE than an average shooter at his position would on the same shots \u2014 with each shot priced by how league shooters actually convert its CONTEXT (danger band \u00d7 strength state \u00d7 rebound), not just its geometry. Trusted more the more he's shot; the band says how sure we are.", "method": "Goals minus cell-expected goals per 100 shots, centered within position, then shrunk toward a shot-speed-informed prior by sample size (younger samples shrink harder). Cells are fit walk-forward \u2014 a season is priced only by the seasons before it. This is the same finishing number the WAR stack uses."}}, "skills": {"hits60": {"receipts": [{"label": "Physicality rate", "value": "8.42 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Physicality", "summary": "Physicality is how often he throws a body check \u2014 counted straight from the NHL's play-by-play. He's logged 360 hits over his last 171 games (8.4 per 60 minutes on the ice), and the grade ranks that against other defensemen.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "blocks60": {"receipts": [{"label": "Shot blocking rate", "value": "3.25 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Shot blocking", "summary": "Shot blocking is how willing he is to get in a shooting lane \u2014 counted straight from the NHL's play-by-play. He's logged 139 blocked shots over his last 171 games (3.2 per 60 minutes on the ice), and the grade ranks that against other defensemen.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "takeaways60": {"receipts": [{"label": "Puck stripping rate", "value": "1.36 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Puck stripping", "summary": "Puck stripping is how often he strips the puck off an opponent \u2014 counted straight from the NHL's play-by-play. He's logged 58 takeaways over his last 171 games (1.4 per 60 minutes on the ice), and the grade ranks that against other defensemen.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "giveaways60": {"receipts": [{"label": "Puck security rate", "value": "3.20 / 60", "tone": "neutral"}, {"label": "Direction", "value": "fewer is better", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Puck security", "summary": "Puck security is how often he turns the puck over (fewer is bet