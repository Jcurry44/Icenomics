erm": null, "inBand": null, "err": null, "actualDate": null}, "explain": {"scorecard": {"value": {"receipts": [{"label": "Even strength (5v5)", "value": "+1.31 WAR", "tone": "pos"}, {"label": "Special teams (PP + PK)", "value": "+0.00 WAR", "tone": "neutral"}, {"label": "Penalty discipline (vs position)", "value": "-0.32 WAR", "tone": "neg"}, {"label": "Faceoffs", "value": "-0.03 WAR", "tone": "neutral"}, {"label": "Total, last 3 seasons", "value": "+0.78 WAR", "tone": "pos", "strong": true}], "summary": "His total on-ice value, converted to WINS (WAR). It adds up everything he does \u2014 even-strength play, the power play and penalty kill, his penalty discipline RELATIVE TO HIS POSITION (defensemen structurally take more than they draw, so only the differential vs other D counts), and faceoffs \u2014 and the grade ranks that total against other players at his position over the last three seasons.", "method": "Total WAR sums these four, each priced in wins. The grade is this player's percentile vs same-position peers over the 3-season window."}, "overall": {"receipts": [{"label": "5v5 xG impact (RAPM)", "value": "+0.25 xG/60", "tone": "pos", "strong": true}, {"label": "\u2014 offense", "value": "+0.20 xG/60", "tone": "pos"}, {"label": "\u2014 defense", "value": "+0.05 xG/60", "tone": "pos"}, {"label": "5v5 sample", "value": "1,501 min", "tone": "neutral"}, {"label": "On-ice xG share", "value": "47.9%", "tone": "neutral"}, {"label": "Relative to team (on \u2212 off ice)", "value": "-3.5%", "tone": "neg"}], "summary": "His two-way impact at 5-on-5: do his team's scoring chances go UP, and the other team's go DOWN, when he's on the ice? We isolate his effect from his linemates, the competition, and where his shifts start \u2014 so it's his fingerprint on the play, not just his teammates' work.", "method": "Teammate-, competition- and zone-start-adjusted 5v5 expected goals, via ridge regression over shift stints. An impact estimate, not a box score."}, "offense": {"receipts": [{"label": "Offensive xG impact (RAPM)", "value": "+0.20 xG/60", "tone": "pos", "strong": true}, {"label": "On-ice xG created", "value": "19", "tone": "neutral"}, {"label": "Relative on-ice xG%", "value": "-3.5%", "tone": "neg"}], "summary": "His effect on the chances his team CREATES at 5-on-5 \u2014 how much shot-quality (expected goals) his line generates with him out there, after adjusting for who he plays with and against.", "method": "His share of 5v5 expected-goals creation, adjusted for who he plays with and against."}, "defense": {"receipts": [{"label": "Defensive xG impact (RAPM)", "value": "+0.05 xG/60", "tone": "pos", "strong": true}, {"label": "On-ice xG allowed", "value": "20", "tone": "neutral"}], "summary": "His effect on the chances his team ALLOWS at 5-on-5 \u2014 how well shot-quality against is held down with him on the ice, after adjusting for teammates and competition. A higher grade means fewer good chances against.", "method": "His suppression of 5v5 expected goals against, teammate- and competition-adjusted. Higher means fewer chances allowed while he's on the ice."}, "finishing": {"receipts": [{"label": "Career shots", "value": "757", "tone": "neutral"}, {"label": "Goals", "value": "53", "tone": "neutral"}, {"label": "Goals above expected", "value": "-2.3", "tone": "neg"}, {"label": "True talent / 100 shots", "value": "-0.18", "tone": "neg", "strong": true}, {"label": "Reliability", "value": "59%", "tone": "neutral"}], "summary": "Whether he scores MORE goals than the quality of his shots would predict \u2014 pure finishing talent. We take his goals minus the expected goals on every shot of his career, then trust it more the more he's shot (a 2,000-shot sample is real; a 200-shot hot streak isn't yet).", "method": "Goals minus expected over career shots, then regressed to the mean by sample size. A high-volume shooter earns a more confident read (higher reliability)."}}, "skills": {"hits60": {"receipts": [{"label": "Physicality rate