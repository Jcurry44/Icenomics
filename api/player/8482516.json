ethod": "Total WAR sums these four, each priced in wins. The grade is this player's percentile vs same-position peers over the 3-season window."}, "overall": {"receipts": [{"label": "5v5 xG impact (RAPM)", "value": "-0.25 xG/60", "tone": "neg", "strong": true}, {"label": "\u2014 offense", "value": "-0.24 xG/60", "tone": "neg"}, {"label": "\u2014 defense", "value": "-0.01 xG/60", "tone": "neutral"}, {"label": "5v5 sample", "value": "1,284 min", "tone": "neutral"}, {"label": "On-ice xG share", "value": "45.5%", "tone": "neutral"}, {"label": "Relative to team (on \u2212 off ice)", "value": "-4.6%", "tone": "neg"}], "summary": "His two-way impact at 5-on-5: do his team's scoring chances go UP, and the other team's go DOWN, when he's on the ice? We isolate his effect from his linemates, the competition, and where his shifts start \u2014 so it's his fingerprint on the play, not just his teammates' work.", "method": "Teammate-, competition- and zone-start-adjusted 5v5 expected goals, via ridge regression over shift stints. An impact estimate, not a box score."}, "offense": {"receipts": [{"label": "Offensive xG impact (RAPM)", "value": "-0.24 xG/60", "tone": "neg", "strong": true}, {"label": "On-ice xG created", "value": "12", "tone": "neutral"}, {"label": "Relative on-ice xG%", "value": "-4.6%", "tone": "neg"}], "summary": "His effect on the chances his team CREATES at 5-on-5 \u2014 how much shot-quality (expected goals) his line generates with him out there, after adjusting for who he plays with and against.", "method": "His share of 5v5 expected-goals creation, adjusted for who he plays with and against."}, "defense": {"receipts": [{"label": "Defensive xG impact (RAPM)", "value": "-0.01 xG/60", "tone": "neutral", "strong": true}, {"label": "On-ice xG allowed", "value": "15", "tone": "neutral"}], "summary": "His effect on the chances his team ALLOWS at 5-on-5 \u2014 how well shot-quality against is held down with him on the ice, after adjusting for teammates and competition. A higher grade means fewer good chances against.", "method": "His suppression of 5v5 expected goals against, teammate- and competition-adjusted. Higher means fewer chances allowed while he's on the ice."}, "finishing": {"receipts": [{"label": "Career shots", "value": "110", "tone": "neutral"}, {"label": "Goals", "value": "3", "tone": "neutral"}, {"label": "Goals above cell-expected", "value": "-0.3", "tone": "neg"}, {"label": "Finishing / 100 shots", "value": "+0.35", "tone": "pos", "strong": true}, {"label": "95% band", "value": "-1.67 \u2026 +2.37", "tone": "neutral"}, {"label": "Sample", "value": "thin", "tone": "neutral"}], "summary": "Whether he converts MORE than an average shooter at his position would on the same shots \u2014 with each shot priced by how league shooters actually convert its CONTEXT (danger band \u00d7 strength state \u00d7 rebound), not just its geometry. Trusted more the more he's shot; the band says how sure we are.", "method": "Goals minus cell-expected goals per 100 shots, centered within position, then shrunk toward a shot-speed-informed prior by sample size (younger samples shrink harder). Cells are fit walk-forward \u2014 a season is priced only by the seasons before it. This is the same finishing number the WAR stack uses."}}, "skills": {"hits60": {"receipts": [{"label": "Physicality rate", "value": "3.60 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Physicality", "summary": "Physicality is how often he throws a body check \u2014 counted straight from the NHL's play-by-play. He's logged 84 hits over his last 97 games (3.6 per 60 minutes on the ice), and the grade ranks that against other defensemen.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "blocks60": {"receipts": [{"label": "Shot blocking rate", "value": "4.89 / 60", "tone": "neutral"}], "method": "P