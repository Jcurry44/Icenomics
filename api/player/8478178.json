eceipts": [{"label": "5v5 xG impact (RAPM)", "value": "+0.15 xG/60", "tone": "pos", "strong": true}, {"label": "\u2014 offense", "value": "+0.08 xG/60", "tone": "pos"}, {"label": "\u2014 defense", "value": "+0.07 xG/60", "tone": "pos"}, {"label": "5v5 sample", "value": "3,567 min", "tone": "neutral"}, {"label": "On-ice xG share", "value": "56.7%", "tone": "neutral"}, {"label": "Relative to team (on \u2212 off ice)", "value": "+3.5%", "tone": "pos"}], "summary": "His two-way impact at 5-on-5: do his team's scoring chances go UP, and the other team's go DOWN, when he's on the ice? We isolate his effect from his linemates, the competition, and where his shifts start \u2014 so it's his fingerprint on the play, not just his teammates' work.", "method": "Teammate-, competition- and zone-start-adjusted 5v5 expected goals, via ridge regression over shift stints. An impact estimate, not a box score."}, "offense": {"receipts": [{"label": "Offensive xG impact (RAPM)", "value": "+0.08 xG/60", "tone": "pos", "strong": true}, {"label": "On-ice xG created", "value": "72", "tone": "neutral"}, {"label": "Relative on-ice xG%", "value": "+3.5%", "tone": "pos"}], "summary": "His effect on the chances his team CREATES at 5-on-5 \u2014 how much shot-quality (expected goals) his line generates with him out there, after adjusting for who he plays with and against.", "method": "His share of 5v5 expected-goals creation, adjusted for who he plays with and against."}, "defense": {"receipts": [{"label": "Defensive xG impact (RAPM)", "value": "+0.07 xG/60", "tone": "pos", "strong": true}, {"label": "On-ice xG allowed", "value": "55", "tone": "neutral"}], "summary": "His effect on the chances his team ALLOWS at 5-on-5 \u2014 how well shot-quality against is held down with him on the ice, after adjusting for teammates and competition. A higher grade means fewer good chances against.", "method": "His suppression of 5v5 expected goals against, teammate- and competition-adjusted. Higher means fewer chances allowed while he's on the ice."}, "ppOffense": {"receipts": [{"label": "Power-play xG impact (RAPM)", "value": "-0.07 xG/60", "tone": "neg", "strong": true}, {"label": "PP ice time", "value": "253 min", "tone": "neutral"}], "summary": "His impact on the POWER PLAY \u2014 how much his team's chances improve with him on the man advantage, graded only against players who actually log power-play minutes (so a bottom-six grinder isn't penalized for never being out there).", "method": "Power-play expected-goals impact, RAPM-adjusted. Graded vs peers who actually play the PP."}, "pkDefense": {"receipts": [{"label": "Penalty-kill xG suppression (RAPM)", "value": "+0.06 xG/60", "tone": "pos", "strong": true}, {"label": "PK ice time", "value": "55 min", "tone": "neutral"}], "summary": "His impact on the PENALTY KILL \u2014 how well his team smothers chances while short-handed with him on the ice, graded against other penalty-killers.", "method": "Penalty-kill expected-goals suppression, RAPM-adjusted."}, "finishing": {"receipts": [{"label": "Career shots", "value": "696", "tone": "neutral"}, {"label": "Goals", "value": "35", "tone": "neutral"}, {"label": "Goals above cell-expected", "value": "+11.4", "tone": "pos"}, {"label": "Finishing / 100 shots", "value": "+1.39", "tone": "pos", "strong": true}, {"label": "95% band", "value": "-0.05 \u2026 +2.84", "tone": "neutral"}, {"label": "Sample", "value": "fair", "tone": "neutral"}], "summary": "Whether he converts MORE than an average shooter at his position would on the same shots \u2014 with each shot priced by how league shooters actually convert its CONTEXT (danger band \u00d7 strength state \u00d7 rebound), not just its geometry. Trusted more the more he's shot; the band says how sure we are.", "method": "Goals minus cell-expected goals per 100 shots, centered within position, then shrunk toward a shot-speed-informed prior by sample size (younger samples shrink harder). Cells are fit walk-forward \u2014 a season is pri