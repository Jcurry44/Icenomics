": true}, {"label": "\u2014 offense", "value": "+0.02 xG/60", "tone": "neutral"}, {"label": "\u2014 defense", "value": "+0.07 xG/60", "tone": "pos"}, {"label": "5v5 sample", "value": "3,106 min", "tone": "neutral"}, {"label": "On-ice xG share", "value": "45.6%", "tone": "neutral"}, {"label": "Relative to team (on \u2212 off ice)", "value": "-1.2%", "tone": "neg"}], "summary": "His two-way impact at 5-on-5: do his team's scoring chances go UP, and the other team's go DOWN, when he's on the ice? We isolate his effect from his linemates, the competition, and where his shifts start \u2014 so it's his fingerprint on the play, not just his teammates' work.", "method": "Teammate-, competition- and zone-start-adjusted 5v5 expected goals, via ridge regression over shift stints. An impact estimate, not a box score."}, "offense": {"receipts": [{"label": "Offensive xG impact (RAPM)", "value": "+0.02 xG/60", "tone": "neutral", "strong": true}, {"label": "On-ice xG created", "value": "46", "tone": "neutral"}, {"label": "Relative on-ice xG%", "value": "-1.2%", "tone": "neg"}], "summary": "His effect on the chances his team CREATES at 5-on-5 \u2014 how much shot-quality (expected goals) his line generates with him out there, after adjusting for who he plays with and against.", "method": "His share of 5v5 expected-goals creation, adjusted for who he plays with and against."}, "defense": {"receipts": [{"label": "Defensive xG impact (RAPM)", "value": "+0.07 xG/60", "tone": "pos", "strong": true}, {"label": "On-ice xG allowed", "value": "56", "tone": "neutral"}], "summary": "His effect on the chances his team ALLOWS at 5-on-5 \u2014 how well shot-quality against is held down with him on the ice, after adjusting for teammates and competition. A higher grade means fewer good chances against.", "method": "His suppression of 5v5 expected goals against, teammate- and competition-adjusted. Higher means fewer chances allowed while he's on the ice."}, "ppOffense": {"receipts": [{"label": "Powe