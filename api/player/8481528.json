."}, "finishing": {"receipts": [{"label": "Career shots", "value": "1,376", "tone": "neutral"}, {"label": "Goals", "value": "110", "tone": "neutral"}, {"label": "Goals above cell-expected", "value": "-10.0", "tone": "neg"}, {"label": "Finishing / 100 shots", "value": "-0.33", "tone": "neg", "strong": true}, {"label": "95% band", "value": "-1.37 \u2026 +0.71", "tone": "neutral"}, {"label": "Sample", "value": "fair", "tone": "neutral"}], "summary": "Whether he converts MORE than an average shooter at his position would on the same shots \u2014 with each shot priced by how league shooters actually convert its CONTEXT (danger band \u00d7 strength state \u00d7 rebound), not just its geometry. Trusted more the more he's shot; the band says how sure we are.", "method": "Goals minus cell-expected goals per 100 shots, centered within position, then shrunk toward a shot-speed-informed prior by sample size (younger samples shrink harder). Cells are fit walk-forward \u2014 a season is priced only by the seasons before it. This is the same finishing number the WAR stack uses."}}, "skills": {"hits60": {"receipts": [{"label": "Physicality rate", "value": "7.61 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Physicality", "summary": "Physicality is how often he throws a body check \u2014 counted straight from the NHL's play-by-play. He's logged 527 hits over his last 243 games (7.6 per 60 minutes on the ice), and the grade ranks that against other forwards.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "blocks60": {"receipts": [{"label": "Shot blocking rate", "value": "1.39 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Shot blocking", "summary": "Shot blocking is how willing he is to get in a shooting lane \u2014 counted straight from the NHL's play-by-play. He's logged 96 blocked shots over his last 243 games (1.4 per 60 minutes on the ice), and the grade ranks that against other forwards.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "takeaways60": {"receipts": [{"label": "Puck stripping rate", "value": "0.89 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Puck stripping", "summary": "Puck stripping is how often he strips the puck off an opponent \u2014 counted straight from the NHL's play-by-play. He's logged 62 takeaways over his last 243 games (0.9 per 60 minutes on the ice), and the grade ranks that against other forwards.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "giveaways60": {"receipts": [{"label": "Puck security rate", "value": "2.27 / 60", "tone": "neutral"}, {"label": "Direction", "value": "fewer is better", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Puck security", "summary": "Puck security is how often he turns the puck over (fewer is better) \u2014 counted straight from the NHL's play-by-play. He's logged 157 giveaways over his last 243 games (2.3 per 60 minutes on the ice), and the grade ranks that against other forwards.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "primary_assists60": {"receipts": [{"label": "Playmaking rate", "value": "0.81 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Playmaking", "summary": "Playmaking is how often he makes the primary pass on a goal \u2014 0.81 per 60 minutes of ice time over his last 3 seasons, ranked against other f