": {"receipts": [{"label": "Offensive xG impact (RAPM)", "value": "-0.13 xG/60", "tone": "neg", "strong": true}, {"label": "On-ice xG created", "value": "23", "tone": "neutral"}, {"label": "Relative on-ice xG%", "value": "-5.2%", "tone": "neg"}], "summary": "His effect on the chances his team CREATES at 5-on-5 \u2014 how much shot-quality (expected goals) his line generates with him out there, after adjusting for who he plays with and against.", "method": "His share of 5v5 expected-goals creation, adjusted for who he plays with and against."}, "defense": {"receipts": [{"label": "Defensive xG impact (RAPM)", "value": "+0.07 xG/60", "tone": "pos", "strong": true}, {"label": "On-ice xG allowed", "value": "26", "tone": "neutral"}], "summary": "His effect on the chances his team ALLOWS at 5-on-5 \u2014 how well shot-quality against is held down with him on the ice, after adjusting for teammates and competition. A higher grade means fewer good chances against.", "method": "His suppression of 5v5 expected goals against, teammate- and competition-adjusted. Higher means fewer chances allowed while he's on the ice."}, "ppOffense": {"receipts": [{"label": "Power-play xG impact (RAPM)", "value": "+0.00 xG/60", "tone": "neutral", "strong": true}, {"label": "PP ice time", "value": "38 min", "tone": "neutral"}], "summary": "His impact on the POWER PLAY \u2014 how much his team's chances improve with him on the man advantage, graded only against players who actually log power-play minutes (so a bottom-six grinder isn't penalized for never being out there).", "method": "Power-play expected-goals impact, RAPM-adjusted. Graded vs peers who actually play the PP."}, "pkDefense": {"receipts": [{"label": "Penalty-kill xG suppression (RAPM)", "value": "-0.16 xG/60", "tone": "neg", "strong": true}, {"label": "PK ice time", "value": "85 min", "tone": "neutral"}], "summary": "His impact on the PENALTY KILL \u2014 how well his team smothers chances while short-handed with him on the ice, graded against other penalty-killers.", "method": "Penalty-kill expected-goals suppression, RAPM-adjusted."}, "finishing": {"receipts": [{"label": "Career shots", "value": "1,271", "tone": "neutral"}, {"label": "Goals", "value": "98", "tone": "neutral"}, {"label": "Goals above expected", "value": "+0.4", "tone": "pos"}, {"label": "True talent / 100 shots", "value": "+0.02", "tone": "neutral", "strong": true}, {"label": "Reliability", "value": "71%", "tone": "neutral"}], "summary": "Whether he scores MORE goals than the quality of his shots would predict \u2014 pure finishing talent. We take his goals minus the expected goals on every shot of his career, then trust it more the more he's shot (a 2,000-shot sample is real; a 200-shot hot streak isn't yet).", "method": "Goals minus expected over career shots, then regressed to the mean by sample size. A high-volume shooter earns a more confident read (higher reliability)."}}, "skills": {"hits60": {"receipts": [{"label": "Physicality rate", "value": "5.57 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Physicality", "summary": "Physicality is how often he throws a body check \u2014 counted straight from the NHL's play-by-play. He's logged 227 hits over his last 181 games (5.6 per 60 minutes on the ice), and the grade ranks that against other forwards.", "caveat": "Home-scorer count -- arena bias is real (some rinks record far more than others). Read big gaps as signal, small ones as noise."}, "blocks60": {"receipts": [{"label": "Shot blocking rate", "value": "1.45 / 60", "tone": "neutral"}], "method": "Per-60 rate over 3 seasons (TOI-weighted), ranked vs same-position peers.", "label": "Shot blocking", "summary": "Shot blocking is how willing he is to get in a shooting lane \u2014 counted straight from the NHL's play-by-play. He's logged 59 blocked shots over his last 181 games (1.4 per 60 minutes on the ice), and the grade ranks that against other f